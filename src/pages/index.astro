---
import Layout from "@/layouts/Layout.astro";
import PassportBoardingPass from "@/components/PassportBoardingPass.tsx";
import SmoothScroll from "@/components/SmoothScroll.tsx";
---

<Layout>
  <SmoothScroll client:load />

  <main class="relative min-h-screen overflow-hidden">
    <!-- ambient background -->
    <div class="aurora pointer-events-none absolute inset-0 -z-10"></div>
    <div
      class="pointer-events-none absolute inset-0 -z-10 opacity-[0.04]"
      style="background-image: radial-gradient(hsl(0 0% 100%) 1px, transparent 1px); background-size: 26px 26px;"
    >
    </div>

    <!-- top bar -->
    <header class="relative z-10 mx-auto flex max-w-6xl items-center justify-between px-6 py-6">
      <div class="flex items-center gap-2 font-semibold tracking-tight">
        <span
          class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-primary/15 text-primary"
        >
          ✈
        </span>
        <span>Wanderlust Air</span>
      </div>
      <nav class="hidden items-center gap-6 text-sm text-muted-foreground sm:flex">
        <span class="inline-flex items-center gap-1">
          <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
          Secure check-in
        </span>
        <span>First Class</span>
      </nav>
    </header>

    <!-- hero -->
    <section
      class="relative z-10 mx-auto grid min-h-[calc(100vh-88px)] max-w-6xl place-items-center px-6 pb-16"
    >
      <div class="flex flex-col items-center gap-10 text-center">
        <div class="flex flex-col items-center gap-5">
          <span
            class="rounded-full border border-border bg-secondary/40 px-4 py-1.5 text-xs font-medium tracking-wide text-muted-foreground"
          >
            Destination unlocked
          </span>
          <h1
            class="max-w-3xl text-balance text-4xl font-extrabold leading-tight tracking-tight sm:text-6xl"
          >
            Your journey to
            <span class="text-shimmer">Jamaica</span>
            starts here
          </h1>
          <p class="max-w-xl text-balance text-base text-muted-foreground sm:text-lg">
            Tap the passport to open your first-class boarding pass. Sound on —
            the captain is ready for takeoff.
          </p>
        </div>

        <PassportBoardingPass client:load />
      </div>
    </section>

    <footer
      class="relative z-10 mx-auto max-w-6xl px-6 py-8 text-center text-xs text-muted-foreground"
    >
      Built with Astro · React · Tailwind · shadcn/ui · Motion · GSAP · Lenis
    </footer>
  </main>
</Layout>

---
import Layout from "@/layouts/Layout.astro";
import PassportBoardingPass from "@/components/PassportBoardingPass.tsx";
import TravelBackground from "@/components/TravelBackground.astro";
import SmoothScroll from "@/components/SmoothScroll.tsx";
---

<Layout>
  <SmoothScroll client:load />

  <main class="relative flex min-h-screen flex-col overflow-x-hidden">
    <!-- travel-themed backdrop -->
    <TravelBackground />

    <!-- passport is the whole experience -->
    <section class="relative z-10 flex flex-1 items-center justify-center px-4 py-4">
      <PassportBoardingPass client:load />
    </section>
  </main>
</Layout>
